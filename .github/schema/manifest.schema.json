{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Manifest schema",
  "description": "Schema for manifest.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema identifier (instance may include this)"
    }
  },
  "additionalProperties": {
    "type": "object",
    "description": "Object representing the relative paths of configuration files included in this manifest (e.g. 'maps/sector_ownership.json')",
    "properties": {
      "folder": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Subfolder of FIR"
      }
    }
  }
}
