{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Views Schema",
  "description": "Schema for views.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema identifier (instance may include this)"
    },
    "version": {
      "type": "string",
      "description": "Version of the views configuration",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    }
  },
  "additionalProperties": {
    "type": "object",
    "additionalProperties": {
      "type": "object",
      "properties": {
        "center": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "zoom": { "type": "number", "minimum": 0, "maximum": 10 }
      },
      "required": ["center", "zoom"],
      "additionalProperties": false
    }
  }
}
